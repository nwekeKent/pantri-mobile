  "author": "Krishna Kumar",
  "license": "MIT",
  "keywords": [
    "expo",
    "react-native",
    "nativewind",
    "tailwindcss",
    "typescript",
    "template",
    "starter",
    "ui-components"
  ],
  "repository": {
    "type": "git",
